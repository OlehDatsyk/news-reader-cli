# -----------------------------------------------------------------------------
# News Reader CLI - Environment Variables Template
# -----------------------------------------------------------------------------
# 1. Copy this file and rename the copy to ".env" (remove ".example").
# 2. Replace the placeholder value below with your real NewsAPI.org API key.
# 3. Never commit your real ".env" file to Git (it is already in .gitignore).
# -----------------------------------------------------------------------------

# Required: Get a free API key at https://newsapi.org/register
NEWS_API_KEY=your_api_key_here

# Optional: Default country code used for "Top headlines" (default: us)
NEWS_DEFAULT_COUNTRY=us
